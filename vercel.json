{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/app/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "rewrites": [],
  "redirects": [],
  "headers": [],
  "crons": [
    {
      "path": "/api/cron/popularity",
      "schedule": "0 3 * * *"
    }
  ]
}
